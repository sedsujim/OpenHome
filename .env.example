HOST=0.0.0.0
PORT=8000
DEBUG=false

# --- Supabase (required) ---
SUPABASE_URL=https://kvuvkikzxthwybtjagml.supabase.co
SUPABASE_SERVICE_KEY=
SUPABASE_JWT_SECRET=

# --- Docker ---
DOCKER_NETWORK=openhome-net
SERVERS_BASE_DIR=/opt/openhome/servers
MC_IMAGE=itzg/minecraft-server:latest

# --- Minecraft Server Paths (fallback for direct java process) ---
SERVER_DIR=./server
SERVER_JAR=server.jar
JAVA_PATH=java
JAVA_XMS=512M
JAVA_XMX=2G
JAVA_FLAGS=-XX:+UseG1GC -XX:+ParallelRefProcEnabled -XX:MaxGCPauseMillis=200 -XX:+UnlockExperimentalVMOptions -XX:+DisableExplicitGC

# --- Playit.gg Tunnel (optional) ---
PLAYIT_API_KEY=
PLAYIT_AGENT_PATH=playit
PLAYIT_TUNNEL_PORT=25565

# --- DuckDNS (optional) ---
DUCKDNS_TOKEN=
DUCKDNS_DOMAIN=

# --- CORS (optional, defaults to all origins) ---
# CORS_ORIGINS=["*"]
