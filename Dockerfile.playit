FROM golang:1.22-alpine AS builder

WORKDIR /build
RUN apk add --no-cache git
RUN git clone https://github.com/playit-cloud/playit-agent.git . \
    && CGO_ENABLED=0 go build -o playit ./cmd/playit

FROM alpine:3.20

RUN apk add --no-cache ca-certificates tzdata
COPY --from=builder /build/playit /usr/local/bin/playit

EXPOSE 25565/tcp

ENTRYPOINT ["playit", "--port", "25565"]
